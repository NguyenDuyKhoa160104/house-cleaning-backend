# 1. Dependency directories (Thư mục thư viện - cực nặng, không nên push)
node_modules/
jspm_packages/

# 2. Environment variables (File cấu hình bí mật - TUYỆT ĐỐI không push)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 3. Logs (Các file nhật ký lỗi)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 4. Runtime data (Dữ liệu tạm thời)
pids
*.pid
*.seed
*.pid.lock

# 5. Testing (Dữ liệu chạy test)
coverage/
.nyc_output

# 6. IDEs and Editors (Cấu hình riêng của trình soạn thảo)
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 7. Operating System Files (File rác của hệ điều hành)
.DS_Store
Thumbs.db

# 8. Build/Dist (Nếu sau này bạn dùng TypeScript hoặc Build tool)
dist/
build/